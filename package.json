{
  "name": "opsbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:intent": "supabase functions serve --no-verify-jwt --env-file .env.local",
    "dev:robot": "set -a; . ./.env.local; set +a; .venv/bin/python -m robot_bridge.server",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:robot": "python3 -m unittest discover -s robot_bridge/tests"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/postcss": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "latest",
    "postcss": "^8.5.15",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
